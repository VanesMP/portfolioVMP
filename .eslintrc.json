{
  "extends": ["next/core-web-vitals", "plugin:prettier/recommended"],
  "plugins": ["react", "react-hooks", "prettier"],
  "rules": {
    "prettier/prettier": [
      "error",
      {
        "singleQuote": false,
        "jsxSingleQuote": false,
        "semi": true,
        "trailingComma": "es5",
        "printWidth": 100,
        "tabWidth": 2
      }
    ]
  }
}